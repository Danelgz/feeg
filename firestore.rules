rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para perfiles de usuario. Documento PRIVADO: aquí vive el historial completo de
    // entrenamientos, medidas corporales y ajustes — solo su dueño puede leerlo. Lo que debe ser
    // público (username, foto, descripción) vive aparte en usersPublic/{userId}.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Subcolección de mensajes del chat IA
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Notificaciones sociales (like/comentario/nuevo seguidor). El dueño es el único que lee,
      // marca como leído o borra; quien dispara la notificación (p.ej. al dar like) es quien la
      // crea, pero solo puede escribirla a nombre de sí mismo y nunca hacia sí mismo.
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid != userId
          && request.resource.data.fromUserId == request.auth.uid;
      }
    }

    match /usersPublic/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Entrenamientos (feed social)
    match /workouts/{workoutId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // El dueño puede editar todo
        (resource.data.userId == request.auth.uid) ||
        // Otros solo pueden editar likes y comentarios, sin cambiar otros campos
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsList']))
      );
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Reglas para publicaciones
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments']) ||
        resource.data.authorId == request.auth.uid
      );
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
  }
}
